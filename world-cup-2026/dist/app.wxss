page{--color-bg:#0f0f23;--color-surface:#1a1a2e;--color-card:#16213e;--color-primary:#00d2ff;--color-accent:#e94560;--color-gold:gold;--color-text:#eaeaea;--color-text-dim:#8e8e93;--color-success:#4caf50;--color-warning:#ff9800;--color-danger:#f44336;background-color:#1a1a2e;color:#fff;font-family:-apple-system,BlinkMacSystemFont,PingFang SC,sans-serif;min-height:100vh}.flex-center{align-items:center;display:flex;justify-content:center}.flex-between{align-items:center;display:flex;justify-content:space-between}.flex-col{display:flex;flex-direction:column}.btn{border-radius:16rpx;font-size:30rpx;font-weight:600;margin:12rpx 0;padding:24rpx 48rpx;text-align:center;transition:all .2s}.btn-primary{background:linear-gradient(135deg,var(--color-primary),#09c);color:#000}.btn-outline{background:transparent;border:2rpx solid var(--color-primary);color:var(--color-primary)}.btn-accent{background:linear-gradient(135deg,var(--color-accent),#c0392b);color:#fff}.btn-reset{border-color:var(--color-text-dim);color:var(--color-text-dim)}.card{background:var(--color-card);border:1rpx solid hsla(0,0%,100%,.06);border-radius:20rpx;margin:16rpx 0;padding:32rpx}.page-container{padding:24rpx 24rpx 120rpx}.section-title{color:var(--color-text);font-size:34rpx;font-weight:700;margin:32rpx 0 16rpx}.text-dim{color:var(--color-text-dim);font-size:26rpx}.text-gold{color:var(--color-gold)}.text-primary{color:var(--color-primary)}