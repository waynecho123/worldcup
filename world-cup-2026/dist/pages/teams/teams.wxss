.teams-page{min-height:100vh}.groups-scroll{height:calc(100vh - 200rpx)}.group-section{margin-bottom:32rpx}.group-title{color:var(--color-primary);font-size:36rpx;font-weight:700;margin-bottom:16rpx;padding-left:8rpx}.team-grid{display:flex;flex-wrap:wrap;gap:16rpx}.team-card{align-items:center;background:var(--color-card);border:2rpx solid transparent;border-radius:16rpx;display:flex;flex-direction:column;gap:8rpx;padding:20rpx 16rpx;transition:all .2s;width:calc(25% - 12rpx)}.team-card.selected{background:rgba(0,210,255,.1);border-color:var(--color-primary)}.team-flag-img{border-radius:4rpx;box-shadow:0 2rpx 6rpx rgba(0,0,0,.3);height:40rpx;width:56rpx}.team-name{font-size:22rpx;line-height:1.2;text-align:center}.team-rank{color:var(--color-text-dim);font-size:20rpx}.selected-badge{background:rgba(0,210,255,.2);border-radius:8rpx;color:var(--color-primary);font-size:18rpx;padding:2rpx 8rpx}