.group-page{min-height:100vh;padding-bottom:160rpx}.groups-container{height:calc(100vh - 200rpx)}.group-card{margin-bottom:20rpx}.group-header{color:var(--color-primary);font-size:32rpx;font-weight:700;margin-bottom:16rpx}.standings-table{margin-bottom:16rpx}.standings-header,.standings-row{align-items:center;display:flex;font-size:24rpx;padding:8rpx 0}.standings-header{border-bottom:1rpx solid hsla(0,0%,100%,.1);color:var(--color-text-dim);font-size:22rpx;padding-bottom:12rpx}.standings-row{border-bottom:1rpx solid hsla(0,0%,100%,.04);padding:12rpx 0}.standings-row.user-row{background:rgba(0,210,255,.06);border-radius:8rpx;padding:12rpx 4rpx}.standings-row.qualified{border-left:4rpx solid var(--color-success)}.standings-row.third{border-left:4rpx solid var(--color-warning)}.col-team{align-items:center;display:flex;flex:3;gap:8rpx;min-width:0}.flag-mini{border-radius:2rpx;flex-shrink:0}.team-label{font-size:24rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.col-stat{flex:1;text-align:center}.col-pts{color:var(--color-gold);flex:1;font-weight:700;text-align:center}.match-results{margin-top:12rpx}.match-row{align-items:center;border-bottom:1rpx solid hsla(0,0%,100%,.03);display:flex;font-size:24rpx;justify-content:space-between;padding:14rpx 0}.match-row.user-match{background:rgba(255,215,0,.05);border-radius:8rpx;padding:14rpx 8rpx}.match-team{flex:2;text-align:center}.match-score{flex:1;font-weight:700;text-align:center}.match-score.pending{color:var(--color-text-dim)}.user-badge{font-size:28rpx}