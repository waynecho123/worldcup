.knockout-page{min-height:100vh}.bracket-scroll{height:calc(100vh - 160rpx);width:100%}.kn-match-node{padding:12rpx}.kn-match-node .kn-round{color:var(--color-primary);font-size:22rpx;font-weight:600;margin-bottom:6rpx}.kn-match-node .kn-teams{background:var(--color-card);border-radius:12rpx;margin-bottom:4rpx;min-width:280rpx;overflow:hidden}.kn-match-node .kn-team{align-items:center;border-bottom:1rpx solid hsla(0,0%,100%,.05);display:flex;font-size:24rpx;gap:8rpx;padding:10rpx 16rpx}.kn-match-node .kn-team.winner{background:rgba(0,210,255,.08)}.kn-match-node .flag-micro{border-radius:2rpx;flex-shrink:0}.kn-match-node .kn-team-name{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.kn-match-node .kn-score{color:var(--color-gold);font-size:26rpx;font-weight:700}.kn-match-node .kn-pens{color:var(--color-text-dim);font-size:20rpx;padding-left:8rpx}.kn-match-node .kn-children{border-left:2rpx solid hsla(0,0%,100%,.1);display:flex;gap:4rpx;margin-left:20rpx;padding-left:12rpx}