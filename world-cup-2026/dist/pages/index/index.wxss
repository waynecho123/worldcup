.home-page{min-height:100vh}.hero-section{padding:32rpx 0;text-align:center}.hero-section .hero-icon{display:block;font-size:80rpx}.hero-section .hero-title{background:linear-gradient(135deg,var(--color-gold),var(--color-accent));-webkit-background-clip:text;display:block;font-size:44rpx;font-weight:800;-webkit-text-fill-color:transparent}.hero-section .hero-subtitle{color:var(--color-text-dim);display:block;font-size:28rpx;margin-top:8rpx}.hero-section .hero-date{color:var(--color-text-dim);font-size:24rpx;margin-top:4rpx}.selected-team-card .card-label{color:var(--color-text-dim);font-size:24rpx;margin-bottom:16rpx}.flag-main{border-radius:6rpx;box-shadow:0 4rpx 12rpx rgba(0,0,0,.4)}.team-name-main{font-size:34rpx;font-weight:700}.select-prompt{padding:48rpx;text-align:center}.select-prompt .prompt-icon{display:block;font-size:64rpx}.select-prompt .prompt-text{display:block;font-size:30rpx;font-weight:600;margin:16rpx 0 8rpx}.action-buttons{margin:24rpx 0}.stats-row{display:flex;justify-content:space-between;margin-top:32rpx}.stats-row .stat-item{flex:1;text-align:center}.stats-row .stat-num{color:var(--color-primary);display:block;font-size:42rpx;font-weight:800}.stats-row .stat-lbl{color:var(--color-text-dim);display:block;font-size:22rpx}