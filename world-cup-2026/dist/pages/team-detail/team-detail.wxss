.team-detail-page{min-height:100vh}.team-header{align-items:center;background:var(--color-card);border-radius:20rpx;display:flex;gap:24rpx;margin-bottom:24rpx;padding:32rpx}.team-flag-lg{border-radius:8rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.4)}.team-header-info{flex:1}.th-name{display:block;font-size:38rpx;font-weight:800}.th-subtitle{color:var(--color-text-dim);display:block;font-size:24rpx;margin-top:4rpx}.players-list{max-height:600rpx}.player-row{align-items:center;background:var(--color-card);border-radius:12rpx;display:flex;justify-content:space-between;margin-bottom:8rpx;padding:16rpx 20rpx}.player-row.starter{border-left:4rpx solid var(--color-primary)}.player-left{align-items:center;display:flex;gap:16rpx}.player-number{color:var(--color-text-dim);font-size:28rpx;font-weight:700;min-width:40rpx}.player-info{display:flex;flex-direction:column}.player-name{font-size:28rpx;font-weight:600}.player-club{color:var(--color-text-dim);font-size:22rpx}.player-right{align-items:center;display:flex;gap:12rpx}.player-pos{color:var(--color-text-dim);font-size:22rpx}.player-ovr{font-size:32rpx;font-weight:800}.key-badge{font-size:24rpx}.attr-row{align-items:center;display:flex;gap:12rpx;padding:6rpx 0}.attr-label{color:var(--color-text-dim);font-size:20rpx;min-width:50rpx}.attr-bar-bg{background:hsla(0,0%,100%,.06);border-radius:5rpx;flex:1;height:10rpx;overflow:hidden}.attr-bar-fill{border-radius:5rpx;height:100%;transition:width .3s}.attr-value{font-size:20rpx;font-weight:600;min-width:36rpx;text-align:right}