.match-page{min-height:100vh}.scoreboard{align-items:center;background:var(--color-card);border-radius:20rpx;display:flex;justify-content:space-between;margin-bottom:24rpx;padding:32rpx;text-align:center}.sb-team{flex:2}.sb-name{font-size:28rpx;font-weight:600}.sb-score{align-items:center;display:flex;flex:1;gap:8rpx;justify-content:center}.sb-num{color:var(--color-gold);font-size:52rpx;font-weight:800}.sb-divider{color:var(--color-text-dim);font-size:40rpx}.sb-pens{color:var(--color-text-dim);display:block;font-size:22rpx;margin-top:4rpx;text-align:center}.winner-banner{background:rgba(255,215,0,.1);border-radius:12rpx;color:var(--color-gold);font-size:28rpx;font-weight:600;margin-bottom:24rpx;padding:16rpx;text-align:center}.match-context{margin-bottom:16rpx}.context-title{color:var(--color-text-dim);font-size:26rpx;margin-bottom:12rpx}.context-grid{display:flex;flex-wrap:wrap;gap:8rpx}.context-item{background:hsla(0,0%,100%,.04);border-radius:8rpx;font-size:24rpx;padding:8rpx 16rpx}.altitude-note{color:var(--color-warning);display:block;font-size:22rpx;margin-top:8rpx}.events-timeline{max-height:500rpx}.event-item{align-items:center;border-bottom:1rpx solid hsla(0,0%,100%,.04);display:flex;gap:12rpx;padding:12rpx 8rpx}.event-item.event-home{border-left:4rpx solid var(--color-primary);padding-left:16rpx}.event-item.event-away{border-left:4rpx solid var(--color-accent);padding-left:16rpx}.event-minute{color:var(--color-text-dim);font-size:24rpx;min-width:50rpx}.event-icon{font-size:28rpx}.event-content{flex:1}.event-desc{font-size:24rpx}.tactics-compare{align-items:flex-start;display:flex;gap:16rpx}.tactic-side{flex:1}.tactic-team{font-size:26rpx;font-weight:600;margin-bottom:8rpx}.tactic-item{color:var(--color-text-dim);font-size:22rpx;padding:4rpx 0}.tactic-vs{color:var(--color-text-dim);font-size:28rpx;padding-top:24rpx}