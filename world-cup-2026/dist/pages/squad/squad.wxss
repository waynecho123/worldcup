.squad-page{min-height:100vh;padding-bottom:160rpx}.formation-bar{margin-bottom:16rpx;padding:16rpx 0;white-space:nowrap}.formation-chip{background:var(--color-card);border:2rpx solid transparent;border-radius:24rpx;display:inline-block;font-size:26rpx;margin-right:16rpx;padding:12rpx 28rpx}.formation-chip.active{background:rgba(0,210,255,.1);border-color:var(--color-primary);color:var(--color-primary)}.pitch{aspect-ratio:3/4;background:linear-gradient(180deg,#2d8a4e,#267a44);border:4rpx solid hsla(0,0%,100%,.3);border-radius:16rpx;margin:16rpx 0;overflow:hidden;position:relative;width:100%}.pitch-markings{inset:0;position:absolute}.pitch-markings .pitch-center-line{background:hsla(0,0%,100%,.4);height:2rpx;left:0;position:absolute;right:0;top:50%}.pitch-markings .pitch-center-circle{border:2rpx solid hsla(0,0%,100%,.4);border-radius:50%;height:120rpx;left:50%;position:absolute;top:50%;transform:translate(-50%,-50%);width:120rpx}.pitch-markings .pitch-box-bottom,.pitch-markings .pitch-box-top{border:2rpx solid hsla(0,0%,100%,.4);height:22%;left:20%;position:absolute;width:60%}.pitch-markings .pitch-box-top{border-bottom:none;top:0}.pitch-markings .pitch-box-bottom{border-top:none;bottom:0}.pitch-slot{align-items:center;background:hsla(0,0%,100%,.15);border:2rpx dashed hsla(0,0%,100%,.4);border-radius:50%;display:flex;height:70rpx;justify-content:center;position:absolute;transform:translate(-50%,-50%);transition:all .2s;width:70rpx}.pitch-slot.selected{background:rgba(255,215,0,.2);border-color:var(--color-gold)}.pitch-slot.filled{background:rgba(0,210,255,.2);border:2rpx solid var(--color-primary);height:80rpx;width:80rpx}.slot-label{color:hsla(0,0%,100%,.6);font-size:18rpx}.slot-player{align-items:center;display:flex;flex-direction:column;position:relative}.slot-name{color:#fff;font-size:18rpx;font-weight:600}.slot-ovr{color:var(--color-gold);font-size:16rpx}.captain-armband{background:var(--color-gold);border-radius:50%;color:#000;font-size:14rpx;font-weight:700;height:24rpx;line-height:24rpx;position:absolute;right:-8rpx;text-align:center;top:-8rpx;width:24rpx}.player-select{margin-top:16rpx}.player-list{max-height:400rpx}.player-row{background:var(--color-card);border-radius:12rpx;display:flex;font-size:26rpx;justify-content:space-between;margin-bottom:8rpx;padding:16rpx 24rpx}.tactics-panel{margin-top:16rpx}.tactic-row{margin-bottom:20rpx}.tactic-label{color:var(--color-text-dim);display:block;font-size:26rpx;margin-bottom:10rpx}.tactic-options{display:flex;flex-wrap:wrap;gap:12rpx}.chip{background:var(--color-card);border:2rpx solid transparent;border-radius:20rpx;font-size:24rpx;padding:10rpx 24rpx}.chip.active{border-color:var(--color-primary);color:var(--color-primary)}.save-bar{background:var(--color-surface);bottom:0;left:0;padding:20rpx 24rpx;position:fixed;right:0;z-index:10}