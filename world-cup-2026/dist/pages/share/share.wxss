.share-page{min-height:100vh}.poster-preview{margin:24rpx 0}.poster-bg{background:linear-gradient(180deg,#1a1a2e,#16213e 50%,#0f3460);border:2rpx solid hsla(0,0%,100%,.1);border-radius:24rpx;min-height:700rpx;padding:48rpx 32rpx;text-align:center}.poster-title{color:var(--color-gold);display:block;font-size:40rpx;font-weight:800}.poster-subtitle{color:var(--color-text-dim);display:block;font-size:24rpx;margin-top:4rpx}.poster-team{align-items:center;display:flex;flex-direction:column;gap:12rpx;margin:32rpx 0}.poster-flag{border-radius:8rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.5)}.poster-team-name{font-size:36rpx;font-weight:700}.poster-result{background:rgba(255,215,0,.08);border-radius:16rpx;margin:32rpx 0;padding:24rpx}.result-label{color:var(--color-text-dim);display:block;font-size:22rpx}.result-value{color:var(--color-gold);display:block;font-size:56rpx;font-weight:800;margin-top:8rpx}.poster-footer{color:var(--color-text-dim);display:block;font-size:20rpx;margin-top:48rpx}.share-actions{margin-top:32rpx}