/* Bracket View Component */

.bracket-container {
  padding: 4px 0;
}

/* Stage Tabs */
.bracket-tabs {
  margin-bottom: 14px;
}

.bracket-tab-list {
  display: flex;
  gap: 4px;
}

.bracket-tab {
  padding: 6px 14px;
  background: #182032;
  border: 1px solid #1a2744;
  border-radius: 16px;
  font-size: 24rpx;
  color: #8899b4;
  font-weight: 600;
  white-space: nowrap;
  flex-shrink: 0;
  transition: all .2s;
}

.bracket-tab.active {
  background: #4da6ff;
  border-color: #4da6ff;
  color: #fff;
  font-weight: 700;
}

/* Rounds */
.bracket-rounds {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.bracket-round {
  /* Each round block */
}

.br-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
  padding: 0 4px;
}

.br-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #e4e8f0;
}

.br-count {
  font-size: 22rpx;
  color: #556680;
  background: #182032;
  padding: 2px 8px;
  border-radius: 8px;
}

/* Match Slot */
.bracket-slot {
  background: #0f1521;
  border: 1px solid #1a2744;
  border-radius: 12px;
  padding: 14px;
  margin-bottom: 8px;
  transition: all .15s;
}

.bracket-slot:active {
  background: #1a2538;
  border-color: #4da6ff;
}

.bracket-slot.played {
  border-left: 3px solid #00c853;
}

/* Meta */
.bs-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
  font-size: 22rpx;
  color: #556680;
}

.bs-date {
  font-weight: 600;
  color: #8899b4;
}

/* Team row */
.bs-team {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 10px;
  border-radius: 8px;
  background: #182032;
  margin-bottom: 4px;
}

.bs-team.winner {
  background: rgba(0,200,83,.06);
  border: 1px solid rgba(0,200,83,.15);
}

.bs-team.loser {
  opacity: 0.6;
}

.bs-flag {
  font-size: 44rpx;
  flex-shrink: 0;
}

.bs-name {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: #e4e8f0;
}

.bs-team.winner .bs-name {
  color: #00c853;
  font-weight: 800;
}

.bs-score {
  font-size: 32rpx;
  font-weight: 800;
  color: #00c853;
  min-width: 24px;
  text-align: center;
}

.winner .bs-score {
  font-size: 36rpx;
}

.bs-tbd {
  font-size: 24rpx;
  color: #556680;
  font-weight: 700;
}

/* Connector */
.bs-connector {
  display: flex;
  justify-content: center;
  padding: 2px 0;
  margin: 0 20px;
}

.bs-line {
  width: 1px;
  height: 8px;
  background: #1a2744;
}

/* PK */
.bs-pk {
  text-align: center;
  font-size: 20rpx;
  color: #f0b90b;
  margin-top: 4px;
}

/* Venue */
.bs-venue {
  margin-top: 8px;
  font-size: 20rpx;
  color: #556680;
}

/* Empty */
.empty-state {
  text-align: center;
  padding: 40px 20px;
  color: #556680;
}

.empty-state .icon {
  font-size: 72rpx;
  display: block;
  margin-bottom: 8px;
}
