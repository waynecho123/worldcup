/* Football Pitch Component */

.pitch-container {
  margin-bottom: 14px;
}

/* Tabs */
.pitch-tabs {
  display: flex;
  gap: 4px;
  margin-bottom: 10px;
}

.pitch-tab {
  flex: 1;
  text-align: center;
  padding: 8px;
  background: #f0f2f5;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  font-size: 24rpx;
  color: #666666;
  transition: all .2s;
}

.pitch-tab.active {
  background: #2563eb;
  border-color: #2563eb;
  color: #fff;
  font-weight: 700;
}

/* Formation label */
.pitch-formation-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
  padding: 0 4px;
}

.pitch-team-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.pitch-formation-badge {
  font-size: 22rpx;
  background: #2563eb;
  color: #fff;
  padding: 3px 12px;
  border-radius: 12px;
  font-weight: 700;
}

/* The Pitch */
.pitch {
  background: linear-gradient(180deg, #0d3b1e 0%, #0a2d15 50%, #0d3b1e 100%);
  border: 2px solid #1a5c30;
  border-radius: 12px;
  padding: 16px 8px;
  position: relative;
  min-height: 320px;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  overflow: hidden;
}

/* Pitch markings */
.pitch-center-line {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 1px;
  background: rgba(255, 255, 255, 0.2);
}

.pitch-center-circle {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80px;
  height: 80px;
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

/* Formation rows */
.pitch-rows {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  height: 100%;
  gap: 16px;
}

.pitch-rows.pitch-away {
  flex-direction: column-reverse;
}

.pitch-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.pitch-row-1 { justify-content: center; }
.pitch-row-2 { padding: 0 20%; }
.pitch-row-3 { padding: 0 8%; }
.pitch-row-4 { padding: 0 4%; }
.pitch-row-5 { padding: 0 2%; }

/* Player dot */
.pitch-player {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  width: 56px;
}

.pp-num {
  font-size: 22rpx;
  color: #f59e0b;
  font-weight: 800;
  display: block;
  background: rgba(0,0,0,.5);
  width: 30px;
  height: 30px;
  line-height: 30px;
  border-radius: 50%;
  border: 1px solid rgba(240,185,11,.3);
  margin-bottom: 2px;
  text-align: center;
}

.pp-name {
  font-size: 20rpx;
  color: #1a1a1a;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 56px;
  display: block;
}
