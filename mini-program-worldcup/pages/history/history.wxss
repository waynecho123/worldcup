/* History - Simulation Records */

.page { padding: 16px; min-height: 100vh; }

.page-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1a1a1a;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}

/* Empty state */
.empty-state {
  text-align: center;
  padding: 60px 20px;
  color: #999999;
}

.empty-state .es-icon {
  font-size: 96rpx;
  display: block;
  margin-bottom: 12px;
}

.empty-state .es-text {
  font-size: 28rpx;
}

/* History List */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.history-item {
  background: #ffffff;
  border: 1px solid #e0e0e0;
  border-radius: 12px;
  padding: 16px;
  transition: background .15s;
}

.history-item .hi-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}

.history-item .hi-runs {
  font-size: 22rpx;
  background: #2563eb;
  color: #fff;
  padding: 3px 10px;
  border-radius: 12px;
  font-weight: 700;
}

.history-item .hi-time {
  font-size: 22rpx;
  color: #999999;
}

.history-item .hi-top3 {
  font-size: 26rpx;
  color: #1a1a1a;
  line-height: 1.5;
}

.history-item .hi-top3 .gold-highlight {
  color: #f59e0b;
  font-weight: 700;
}

/* Back button */
.back-btn {
  margin-top: 20px;
  text-align: center;
}

.back-btn button {
  background: transparent;
  color: #2563eb;
  border: 1px solid #2563eb;
  border-radius: 8px;
  padding: 10px 30px;
  font-size: 28rpx;
}
