/* Dashboard - Monte Carlo Simulation Page */

.page { padding: 14px; min-height: 100vh; }

/* Controls Card */
.ctrl-card {
  background: #0f1521;
  border: 1px solid #1a2744;
  border-radius: 12px;
  padding: 18px;
  margin-bottom: 16px;
  box-shadow: 0 4px 32px rgba(0,0,0,.4);
}

.ctrl-card .cc-header {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 8px;
  padding-bottom: 10px;
  border-bottom: 1px solid #1a2744;
}

.ctrl-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}

/* Progress */
.progress-wrap {
  height: 10px;
  background: #182032;
  border-radius: 5px;
  overflow: hidden;
  margin: 10px 0;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4da6ff, #8b5cf6);
  border-radius: 5px;
  transition: width 0.2s ease;
}

.progress-text {
  font-size: 22rpx;
  color: #8899b4;
  text-align: center;
  margin-top: 4px;
}

/* Results */
.result-card {
  background: #0f1521;
  border: 1px solid #1a2744;
  border-radius: 12px;
  padding: 18px;
  margin-bottom: 16px;
  box-shadow: 0 4px 32px rgba(0,0,0,.4);
}

.result-card .rc-header {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 8px;
  padding-bottom: 10px;
  border-bottom: 1px solid #1a2744;
}

.champ-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 10px;
  margin: 4px 0;
  background: #182032;
  border-radius: 10px;
  transition: background .15s;
}

.champ-row:nth-child(1) {
  background: linear-gradient(90deg, rgba(240,185,11,.12), rgba(240,185,11,.02));
  border: 1px solid rgba(240,185,11,.2);
}

.champ-row:nth-child(2) {
  background: linear-gradient(90deg, rgba(192,192,192,.08), rgba(192,192,192,.01));
}

.champ-row:nth-child(3) {
  background: linear-gradient(90deg, rgba(205,127,50,.08), rgba(205,127,50,.01));
}

.champ-row .cr-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.champ-row .cr-pos {
  font-size: 36rpx;
  font-weight: 800;
  width: 40px;
  text-align: center;
  color: #556680;
}

.champ-row:nth-child(1) .cr-pos { color: #f0b90b; }
.champ-row:nth-child(2) .cr-pos { color: #c0c0c0; }
.champ-row:nth-child(3) .cr-pos { color: #cd7f32; }

.champ-row .cr-flag {
  font-size: 50rpx;
}

.champ-row .cr-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #e4e8f0;
}

.champ-row .cr-prob {
  font-size: 40rpx;
  font-weight: 800;
  color: #f0b90b;
}

.champ-row .cr-prob-unit {
  font-size: 24rpx;
  color: #8899b4;
}

/* Prob bar */
.prob-bar-wrap {
  height: 6px;
  background: #182032;
  border-radius: 3px;
  overflow: hidden;
  margin-top: 6px;
}

.prob-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #f0b90b, #ff9100);
  border-radius: 3px;
  transition: width 0.5s ease;
}

/* More top teams */
.more-teams {
  margin-top: 8px;
}

.more-teams .mt-title {
  font-size: 24rpx;
  color: #556680;
  margin-bottom: 6px;
}

.more-team-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 10px;
  background: #182032;
  border-radius: 8px;
  margin-bottom: 4px;
}

.more-team-row .mt-name {
  font-size: 26rpx;
  color: #8899b4;
}

.more-team-row .mt-prob {
  font-size: 26rpx;
  font-weight: 700;
  color: #4da6ff;
}

/* Runs info */
.runs-info {
  font-size: 22rpx;
  color: #556680;
  text-align: center;
  margin-top: 10px;
  display: block;
}

/* History button */
.hist-btn {
  margin-top: 12px;
}
