/* Today's Matches - 世界杯赛程 */
page { background-color: #f5f5f5; }

/* Date Navigation */
.date-nav {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 10px;
  background: #ffffff;
  margin: 8px 14px;
  border-radius: 10px;
}

.date-nav-arrow {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666666;
  flex-shrink: 0;
}

.date-scroll {
  flex: 1;
  white-space: nowrap;
}

.date-list {
  display: inline-flex;
  gap: 6px;
  padding: 2px 0;
}

.date-chip {
  padding: 6px 14px;
  border: 1px solid #e0e0e0;
  border-radius: 16px;
  font-size: 22rpx;
  color: #666666;
  background: #ffffff;
  white-space: nowrap;
  flex-shrink: 0;
}

.date-chip.active {
  background: #2563eb;
  color: #fff;
  border-color: #2563eb;
}

.date-chip.past {
  opacity: 0.5;
}

/* Date Header */
.date-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 0 14px 10px;
  padding: 10px 14px;
  flex-wrap: wrap;
}

.date-badge {
  background: #2563eb;
  color: #fff;
  padding: 5px 12px;
  border-radius: 16px;
  font-weight: 700;
  font-size: 24rpx;
  white-space: nowrap;
}

/* Match Cards */
.match-card { margin: 0 14px 10px; }
.match-card.featured { border-left: 3px solid #f59e0b; }

.match-card .mc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4px;
}

.match-card .mc-time { font-size: 22rpx; color: #999999; font-weight: 600; }

.match-card .mc-group {
  font-size: 20rpx;
  color: #2563eb;
  background: rgba(77,166,255,.1);
  padding: 2px 8px;
  border-radius: 4px;
  font-weight: 600;
}

.match-card .mc-result-tag {
  font-size: 20rpx;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 4px;
}

/* 1. Teams row — large display */
.mc-teams-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 8px 0 4px;
}
.mc-teams-row .mc-team { flex: 1; text-align: center; }
.mc-teams-row .mc-flag { font-size: 72rpx; display: block; margin-bottom: 4px; }
.mc-teams-row .mc-name { font-weight: 800; font-size: 30rpx; }
.mc-vs-text {
  font-size: 32rpx;
  font-weight: 800;
  color: #999999;
  margin: 0 2px;
  flex-shrink: 0;
}

/* TBD match */
.mc-tbd { justify-content: center; padding: 12px 0; }

/* 2. Real score banner (post-match) */
.mc-result-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-top: 6px;
  padding: 10px;
  background: rgba(255,61,87,.06);
  border: 1px solid;
  border-radius: 8px;
}
.mc-result-icon { font-size: 28rpx; }
.mc-result-score { font-size: 44rpx; font-weight: 800; }
.mc-result-label { font-size: 20rpx; color: #666666; }

/* 3. AI win prediction text */
.mc-ai-win {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  margin-top: 8px;
}
.mc-ai-win-label { font-size: 24rpx; color: #f59e0b; }
.mc-ai-win-value { font-size: 30rpx; font-weight: 800; color: #f59e0b; }
.mc-ai-win-correct { font-size: 22rpx; color: #16a34a; font-weight: 700; }
.mc-ai-win-wrong { font-size: 22rpx; color: #dc2626; font-weight: 700; }

/* 4. AI predicted score */
.mc-ai-score {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  margin-top: 2px;
}
.mc-ai-score-label { font-size: 22rpx; color: #999999; }
.mc-ai-score-value { font-size: 28rpx; font-weight: 700; color: #f59e0b; }

/* Upset alert */
.mc-upset-alert {
  text-align: center;
  margin-top: 6px;
  padding: 6px 10px;
  font-size: 22rpx;
  font-weight: 700;
  color: #ea580c;
  background: rgba(255,145,0,.08);
  border: 1px solid rgba(255,145,0,.2);
  border-radius: 6px;
}

/* 5. News section */
.mc-news-section { margin-top: 6px; }
.mc-news-line {
  display: block;
  font-size: 22rpx;
  color: #ea580c;
  padding: 3px 8px;
  margin-top: 3px;
  background: rgba(255,145,0,.06);
  border-radius: 4px;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.mc-inj-line {
  display: block;
  font-size: 22rpx;
  color: #dc2626;
  padding: 3px 8px;
  margin-top: 3px;
  background: rgba(255,61,87,.06);
  border-radius: 4px;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 6. Probability bar — compact horizontal bar */
.mc-prob-bar {
  display: flex;
  height: 20px;
  border-radius: 6px;
  overflow: hidden;
  margin-top: 6px;
  background: rgba(255,255,255,.03);
}
.mc-prob-seg {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 700;
  color: #fff;
  min-width: 0;
  overflow: hidden;
}
.mc-prob-seg.home { background: #2563eb; }
.mc-prob-seg.draw { background: #999999; }
.mc-prob-seg.away { background: #dc2626; }
