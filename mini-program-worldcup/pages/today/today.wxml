<!-- Today's Matches - 世界杯赛程 -->
<view class="page bg-dark">

  <!-- Date Nav -->
  <view class="date-nav">
    <view class="date-nav-arrow" bindtap="onPrevDay" wx:if="{{activeIdx > 0}}">◀</view>
    <view wx:else style="width:32px"></view>
    <scroll-view scroll-x enhanced show-scrollbar="{{false}}" class="date-scroll">
      <view class="date-list">
        <view wx:for="{{dates}}" wx:key="date"
              class="date-chip {{activeIdx === index ? 'active' : ''}} {{item.date < '2026-06-17' ? 'past' : ''}}"
              data-idx="{{index}}" bindtap="onDateTap">{{item.label}}</view>
      </view>
    </scroll-view>
    <view class="date-nav-arrow" bindtap="onNextDay" wx:if="{{activeIdx < dates.length - 1}}">▶</view>
    <view wx:else style="width:32px"></view>
  </view>

  <!-- Date Header -->
  <view class="date-header bg-surface2 radius-sm">
    <text class="date-badge">{{dateLabel}}</text>
    <text class="font-s text-secondary">{{matchCount}} 场比赛 · {{stageInfo || '小组赛第'+matchday+'轮'}}</text>
    <text wx:if="{{correctLabel}}" class="font-s text-green font-bold">{{correctLabel}}</text>
  </view>

  <view wx:if="{{testInfo}}" class="font-xs text-secondary" style="text-align:center;padding:4px">{{testInfo}}</view>

  <!-- Empty State -->
  <view wx:if="{{!loading && matchCount === 0}}" class="empty-state">
    <text class="icon">📅</text>
    <text>该日期无比赛</text>
  </view>

  <!-- Match Cards -->
  <view wx:for="{{matches}}" wx:key="id" class="match-card {{item.featured ? 'featured' : ''}}"
        data-id="{{item.id}}" bindtap="onMatchTap">

    <!-- Header: time + group/stage -->
    <view class="mc-header">
      <text class="mc-time">{{item.time}}</text>
      <text wx:if="{{item.group}}" class="mc-group">{{item.group}} 组</text>
      <text wx:elif="{{item.stageLabel}}" class="mc-group">{{item.stageLabel}}</text>
      <text wx:if="{{item.actual}}" class="mc-result-tag" style="color:{{item.actual.color}}">已录入</text>
    </view>

    <!-- TBD Match (KO with unknown teams) -->
    <view wx:if="{{item.isTBD}}" class="mc-tbd">
      <text class="font-m text-muted">{{item.homeName}} vs {{item.awayName}}</text>
    </view>

    <!-- Normal Match -->
    <block wx:else>
      <!-- 1. TEAMS — large flags + names -->
      <view class="mc-teams-row">
        <view class="mc-team">
          <text class="mc-flag">{{item.homeFlag}}</text>
          <text class="mc-name">{{item.homeName}}</text>
        </view>
        <text class="mc-vs-text">VS</text>
        <view class="mc-team">
          <text class="mc-flag">{{item.awayFlag}}</text>
          <text class="mc-name">{{item.awayName}}</text>
        </view>
      </view>

      <!-- 2. REAL SCORE (post-match only) -->
      <view wx:if="{{item.actual}}" class="mc-result-banner" style="border-color:{{item.actual.color}}">
        <text class="mc-result-icon">{{item.actual.icon}}</text>
        <text class="mc-result-score" style="color:{{item.actual.color}}">{{item.actual.homeScore}} : {{item.actual.awayScore}}</text>
        <text class="mc-result-label">最终比分</text>
      </view>

      <!-- 3. AI WIN/LOSS PREDICTION -->
      <view class="mc-ai-win">
        <text class="mc-ai-win-label">🏆 AI预测：</text>
        <text class="mc-ai-win-value">{{item.winByNText}}</text>
        <text wx:if="{{item.actual && item.actual.icon === '🎯'}}" class="mc-ai-win-correct">🎯 命中</text>
        <text wx:elif="{{item.actual && item.actual.icon === '✅'}}" class="mc-ai-win-correct">✅ 正确</text>
        <text wx:elif="{{item.actual && item.actual.icon === '❌'}}" class="mc-ai-win-wrong">❌ 错误</text>
      </view>

      <!-- 4. AI PREDICTED SCORE -->
      <view class="mc-ai-score">
        <text class="mc-ai-score-label">🤖 预测比分</text>
        <text class="mc-ai-score-value">{{item.predScore}}</text>
      </view>

      <!-- Upset Alert -->
      <view wx:if="{{item.upsetAlert}}" class="mc-upset-alert">
        <text>⚠️ 爆冷预警：{{item.upsetTeam}}有{{item.upsetProb}}%冷门可能</text>
      </view>

      <!-- 5. NEWS (hidden when match locked) -->
      <view wx:if="{{!item.isLocked && (item.homeNews || item.awayNews || item.homeInjShort || item.awayInjShort)}}" class="mc-news-section">
        <text wx:if="{{item.homeNews}}" class="mc-news-line">📰 {{item.homeName}}：{{item.homeNews}}</text>
        <text wx:if="{{item.awayNews}}" class="mc-news-line">📰 {{item.awayName}}：{{item.awayNews}}</text>
        <text wx:if="{{item.homeInjShort}}" class="mc-inj-line">🏥 {{item.homeName}}：{{item.homeInjShort}}</text>
        <text wx:if="{{item.awayInjShort}}" class="mc-inj-line">🏥 {{item.awayName}}：{{item.awayInjShort}}</text>
      </view>

      <!-- 6. WIN PROBABILITY — compact bar -->
      <view wx:if="{{!item.isTBD}}" class="mc-prob-bar">
        <view class="mc-prob-seg home" style="width:{{item.homeProb}}%">
          <text wx:if="{{item.homeProb > 15}}">胜 {{item.homeProb}}%</text>
        </view>
        <view class="mc-prob-seg draw" style="width:{{item.drawProb}}%">
          <text wx:if="{{item.drawProb > 15}}">平 {{item.drawProb}}%</text>
        </view>
        <view class="mc-prob-seg away" style="width:{{item.awayProb}}%">
          <text wx:if="{{item.awayProb > 15}}">负 {{item.awayProb}}%</text>
        </view>
      </view>
    </block>
  </view>
</view>
