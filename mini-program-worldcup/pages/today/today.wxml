<!-- Today's Matches - 世界杯赛程 -->
<view class="page bg-dark">

  <!-- Date Nav -->
  <view class="date-nav">
    <view class="date-nav-arrow" bindtap="onPrevDay" wx:if="{{activeIdx > 0}}">◀</view>
    <view wx:else style="width:32px"></view>
    <scroll-view scroll-x enhanced show-scrollbar="{{false}}" class="date-scroll">
      <view class="date-list">
        <view wx:for="{{dates}}" wx:key="date"
              class="date-chip {{activeIdx === index ? 'active' : ''}} {{item.date < '2026-06-17' ? 'past' : ''}}"
              data-idx="{{index}}" bindtap="onDateTap">{{item.label}}</view>
      </view>
    </scroll-view>
    <view class="date-nav-arrow" bindtap="onNextDay" wx:if="{{activeIdx < dates.length - 1}}">▶</view>
    <view wx:else style="width:32px"></view>
  </view>

  <!-- Date Header -->
  <view class="date-header bg-surface2 radius-sm">
    <text class="date-badge">{{dateLabel}}</text>
    <text class="font-s text-secondary">{{matchCount}} 场比赛 · {{stageInfo || '小组赛第'+matchday+'轮'}}</text>
    <text wx:if="{{correctLabel}}" class="font-s text-green font-bold">{{correctLabel}}</text>
  </view>

  <view wx:if="{{testInfo}}" class="font-xs text-secondary" style="text-align:center;padding:4px">{{testInfo}}</view>

  <!-- Empty State -->
  <view wx:if="{{!loading && matchCount === 0}}" class="empty-state">
    <text class="icon">📅</text>
    <text>该日期无比赛</text>
  </view>

  <!-- Match Cards -->
  <view wx:for="{{matches}}" wx:key="id" class="match-card {{item.featured ? 'featured' : ''}}"
        data-id="{{item.id}}" bindtap="onMatchTap">

    <view class="mc-header">
      <text class="mc-time">{{item.time}}</text>
      <text wx:if="{{item.group}}" class="mc-group">{{item.group}} 组</text>
      <text wx:elif="{{item.stageLabel}}" class="mc-group">{{item.stageLabel}}</text>
    </view>

    <!-- TBD Match (KO with unknown teams) -->
    <view wx:if="{{item.isTBD}}" class="mc-teams" style="justify-content:center;padding:12px 0">
      <text class="font-m text-muted">{{item.homeName}} vs {{item.awayName}}</text>
    </view>

    <!-- Normal Match -->
    <view wx:else class="mc-teams">
      <view class="mc-team">
        <text class="mc-flag">{{item.homeFlag}}</text>
        <text class="mc-name">{{item.homeName}}</text>
      </view>
      <view class="mc-vs">
        <text class="mc-pred-score">{{item.predScore}}</text>
        <text class="font-xs" style="color:#4da6ff">AI预测</text>
      </view>
      <view class="mc-team">
        <text class="mc-flag">{{item.awayFlag}}</text>
        <text class="mc-name">{{item.awayName}}</text>
      </view>
    </view>

    <view wx:if="{{!item.actual && !item.isTBD}}" class="mc-probs">
      <text class="font-xs">{{item.homeName}}胜 {{item.homeProb}}%</text>
      <text class="font-xs" style="margin:0 8px;color:#556680">平 {{item.drawProb}}%</text>
      <text class="font-xs">{{item.awayName}}胜 {{item.awayProb}}%</text>
    </view>

    <view wx:if="{{item.actual}}" style="margin-top:8px;padding:8px;background:rgba(255,61,87,.06);border-radius:6px;text-align:center">
      <text class="font-xs">🤖AI {{item.predScore}} → 📡实际 </text>
      <text class="font-m font-bold" style="color:{{item.actual.color}}">{{item.actual.homeScore}}:{{item.actual.awayScore}}</text>
      <text class="font-xs" style="margin-left:4px">{{item.actual.icon}}</text>
    </view>
  </view>
</view>
